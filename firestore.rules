rules_version = '2';

// =====================================================
// GymTrainer Pro – Firestore Security Rules
// Pega estas reglas en:
//   Firebase Console → Firestore Database → Rules
// =====================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Perfiles de usuarios ────────────────────────
    // Lectura pública: necesaria para listar entrenadores
    // en el formulario de registro (antes de tener cuenta)
    match /users/{userId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── Resto de colecciones ────────────────────────
    // Cualquier usuario autenticado puede leer/escribir.
    // La seguridad real está en que solo el entrenador
    // crea cuentas, por lo que solo usuarios de confianza
    // tienen acceso al sistema.
    match /routines/{docId} {
      allow read, write: if request.auth != null;
    }

    match /mealPlans/{docId} {
      allow read, write: if request.auth != null;
    }

    match /measurements/{docId} {
      allow read, write: if request.auth != null;
    }

    match /customExercises/{docId} {
      allow read, write: if request.auth != null;
    }

    match /progressPhotos/{docId} {
      allow read, write: if request.auth != null;
    }

    match /exercisePhotos/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
